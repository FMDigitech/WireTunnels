        <item>
            <title>Version 1.0</title>
            <pubDate>Sun, 06 Jul 2026 00:00:00 +0000</pubDate>
            <sparkle:version>1</sparkle:version>
            <sparkle:shortVersionString>1.0</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <ul>
                    <li>Initial release of WireTunnels</li>
                    <li>Manage WireGuard tunnels from the menu bar and dashboard</li>
                    <li>Privileged helper for secure tunnel management</li>
                    <li>Import, create, and edit tunnel configurations</li>
                    <li>Auto-connect on network changes</li>
                </ul>
            ]]></description>
